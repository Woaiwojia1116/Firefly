---
import fs from "node:fs";
import path from "node:path";
import { footerConfig, profileConfig, siteConfig } from "@/config";
import { url } from "@/utils/url-utils";

const currentYear = new Date().getFullYear();

// 读取FooterConfig.html文件内容
let customFooterHtml = "";
if (footerConfig.enable) {
	try {
		const footerConfigPath = path.join(
			process.cwd(),
			"src",
			"config",
			"FooterConfig.html",
		);
		customFooterHtml = fs.readFileSync(footerConfigPath, "utf-8");
		// 移除HTML注释
		customFooterHtml = customFooterHtml.replace(/<!--[\s\S]*?-->/g, "").trim();
	} catch (error) {
		console.warn("FooterConfig.html文件读取失败:", error.message);
	}
}

const siteStartDate = siteConfig.siteStartDate || "2026-05-06";
const timezone = siteConfig.timezone || "Asia/Shanghai";
---


<div
  class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed mx-32"
>
</div>

<!-- 页脚装饰波浪线 -->
<div class="relative mx-auto max-w-(--page-width) px-4 md:px-8 mb-4">
  <svg
    class="w-full h-10 opacity-40 dark:opacity-30"
    viewBox="0 0 1200 40"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="footer-wave-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color:oklch(0.7 0.14 var(--hue));stop-opacity:0" />
        <stop offset="20%" style="stop-color:oklch(0.7 0.14 var(--hue));stop-opacity:0.6" />
        <stop offset="50%" style="stop-color:oklch(0.75 0.14 var(--hue));stop-opacity:1" />
        <stop offset="80%" style="stop-color:oklch(0.7 0.14 var(--hue));stop-opacity:0.6" />
        <stop offset="100%" style="stop-color:oklch(0.7 0.14 var(--hue));stop-opacity:0" />
      </linearGradient>
    </defs>
    <path
      d="M0,20 Q150,5 300,20 T600,20 T900,20 T1200,20"
      fill="none"
      stroke="url(#footer-wave-gradient)"
      stroke-width="1.5"
      stroke-linecap="round"
    />
    <path
      d="M0,25 Q200,10 400,25 T800,25 T1200,25"
      fill="none"
      stroke="url(#footer-wave-gradient)"
      stroke-width="1"
      stroke-linecap="round"
      opacity="0.5"
    />
  </svg>
</div>

<div
  class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 flex flex-col items-center justify-center px-6"
>
  <div class="transition text-50 text-sm text-center wrap">
    <div class="mb-2">
      {customFooterHtml && <div set:html={customFooterHtml} />}
    </div>
    <div class="m-0.5 text-lg font-bold">
      小破站已降临这个世界：
      <span id="live-clock" data-start={siteStartDate} data-timezone={timezone}></span>
    </div>
    <div class="m-0.5">
      &copy; <span id="copyright-year">{currentYear}</span>
      {profileConfig.name}. All Rights Reserved. /
      <a class="transition link text-(--primary) font-medium" target="_blank" href={url("rss.xml")}>RSS</a> /
      <a class="transition link text-(--primary) font-medium" target="_blank" href={url("sitemap-index.xml")}>Sitemap</a>
    </div>
    <div class="m-0.5">
      Powered by
      <a class="transition link text-(--primary) font-medium" target="_blank" href="https://astro.build">Astro</a> &amp;
      <a class="transition link text-(--primary) font-medium" target="_blank" href="https://github.com/CuteLeaf/Firefly">Firefly</a>
    </div>
    <script is:inline>
      (function() {
        // 防止 Swup 导航时重复创建定时器
        if (window.__liveClockInterval) return;

        var el = document.getElementById('live-clock');
        if (!el) return;
        var startStr = el.getAttribute('data-start');
        var startDate = new Date(startStr + 'T00:00:00');
        function tick() {
          var now = new Date();
          var diff = Math.floor((now - startDate) / 1000);
          if (diff < 0) diff = 0;
          var days = Math.floor(diff / 86400);
          var hours = Math.floor((diff % 86400) / 3600);
          var minutes = Math.floor((diff % 3600) / 60);
          var seconds = diff % 60;
          var pad = function(n) { return n < 10 ? '0' + n : '' + n; };
          var parts = [];
          if (days > 0) parts.push(days + '天');
          parts.push(pad(hours) + '时' + pad(minutes) + '分' + pad(seconds) + '秒');
          el.textContent = parts.join('');
        }
        tick();
        window.__liveClockInterval = setInterval(tick, 1000);
      })();
    </script>
    <!-- 
      注意：请勿随意修改或删除 "Powered by Astro & Firefly" 部分，这是对开源项目的尊重和支持。
      如果您需要在底部增加内容，请在src/config/footerConfig.ts中修改enable属性为true，然后编辑src/config/FooterConfig.html文件。
      您可以随意在src/config/FooterConfig.html中随意添加自定义内容，不需要修改Footer.astro文件。
    -->
  </div>
</div>
