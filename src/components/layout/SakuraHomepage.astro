/* ===== 樱花花瓣飘落效果 ===== */
.sakura-petals {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 50;
  overflow: hidden;
}

.petal {
  position: absolute;
  width: 10px;
  height: 10px;
  background: linear-gradient(
    135deg,
    var(--sakura-light) 0%,
    var(--sakura-pink) 50%,
    var(--cherry-blossom) 100%
  );
  border-radius: 50% 0 50% 50%;
  opacity: 0;
  box-shadow:
    0 0 6px rgba(255, 182, 193, 0.6),
    0 0 12px rgba(255, 182, 193, 0.3);
}

.petal::before {
  content: '';
  position: absolute;
  inset: 1px;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.9) 0%,
    rgba(255, 255, 255, 0) 50%
  );
  border-radius: inherit;
}

/* 为每个花瓣设置不同的动画 */
.petal:nth-child(1) {
  left: 5%;
  animation: petal-fall-1 8s ease-in-out infinite;
  animation-delay: 0s;
}

.petal:nth-child(2) {
  left: 15%;
  animation: petal-fall-2 9s ease-in-out infinite;
  animation-delay: 0.5s;
  width: 8px;
  height: 8px;
}

.petal:nth-child(3) {
  left: 25%;
  animation: petal-fall-3 7.5s ease-in-out infinite;
  animation-delay: 1s;
}

.petal:nth-child(4) {
  left: 35%;
  animation: petal-fall-1 10s ease-in-out infinite;
  animation-delay: 1.5s;
  width: 6px;
  height: 6px;
}

.petal:nth-child(5) {
  left: 45%;
  animation: petal-fall-2 8.5s ease-in-out infinite;
  animation-delay: 2s;
}

.petal:nth-child(6) {
  left: 55%;
  animation: petal-fall-3 9.5s ease-in-out infinite;
  animation-delay: 0.8s;
  width: 7px;
  height: 7px;
}

.petal:nth-child(7) {
  left: 65%;
  animation: petal-fall-1 8.2s ease-in-out infinite;
  animation-delay: 2.5s;
}

.petal:nth-child(8) {
  left: 75%;
  animation: petal-fall-2 9.8s ease-in-out infinite;
  animation-delay: 1.2s;
  width: 9px;
  height: 9px;
}

.petal:nth-child(9) {
  left: 85%;
  animation: petal-fall-3 7.8s ease-in-out infinite;
  animation-delay: 0.3s;
}

.petal:nth-child(10) {
  left: 95%;
  animation: petal-fall-1 10.5s ease-in-out infinite;
  animation-delay: 1.8s;
  width: 5px;
  height: 5px;
}

@keyframes petal-fall-1 {
  0% {
    opacity: 0;
    transform: translateY(-10vh) rotate(0deg) translateX(0);
  }
  10% {
    opacity: 0.8;
  }
  90% {
    opacity: 0.6;
  }
  100% {
    opacity: 0;
    transform: translateY(110vh) rotate(720deg) translateX(100px);
  }
}

@keyframes petal-fall-2 {
  0% {
    opacity: 0;
    transform: translateY(-10vh) rotate(0deg) translateX(0);
  }
  15% {
    opacity: 0.7;
  }
  85% {
    opacity: 0.5;
  }
  100% {
    opacity: 0;
    transform: translateY(110vh) rotate(-540deg) translateX(-80px);
  }
}

@keyframes petal-fall-3 {
  0% {
    opacity: 0;
    transform: translateY(-10vh) rotate(0deg) translateX(0);
  }
  20% {
    opacity: 0.6;
  }
  80% {
    opacity: 0.4;
  }
  100% {
    opacity: 0;
    transform: translateY(110vh) rotate(360deg) translateX(60px);
  }
}

