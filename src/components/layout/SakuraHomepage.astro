---
import { backgroundWallpaper, siteConfig } from "@/config";

interface Props {
	title?: string;
	subtitle?: string | string[];
}

const {
	title = siteConfig.title,
	subtitle = backgroundWallpaper.banner?.homeText?.subtitle || [],
} = Astro.props;

// Ensure subtitle is always an array
const subtitleArray = Array.isArray(subtitle) ? subtitle : [subtitle];
---

<!-- 樱花飘落效果增强版 -->
<div class="sakura-homepage">
  <!-- 背景装饰层 -->
  <div class="background-decorations">
    <!-- 渐变光晕 -->
    <div class="light-blob light-blob-1"></div>
    <div class="light-blob light-blob-2"></div>
    <div class="light-blob light-blob-3"></div>

    <!-- 装饰性花瓣群 -->
    <div class="petal-cluster petal-cluster-1">
      <span class="deco-petal"></span>
      <span class="deco-petal"></span>
      <span class="deco-petal"></span>
    </div>
    <div class="petal-cluster petal-cluster-2">
      <span class="deco-petal"></span>
      <span class="deco-petal"></span>
      <span class="deco-petal"></span>
    </div>
  </div>

  <!-- 导航栏 -->
  <nav class="anime-navbar">
    <div class="navbar-container">
      <div class="navbar-brand">
        <span class="brand-icon">🌸</span>
        <span class="brand-title">{title}</span>
      </div>
      <div class="navbar-menu">
        <a href="/" class="nav-link active">首页</a>
        <a href="/archive" class="nav-link">归档</a>
        <a href="/bangumi" class="nav-link">番组</a>
        <a href="/gallery" class="nav-link">相册</a>
        <a href="/about" class="nav-link">关于</a>
      </div>
      <div class="navbar-actions">
        <button class="nav-btn search-btn" title="搜索">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <button class="nav-btn theme-btn" title="切换主题">
          <svg class="btn-icon sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="btn-icon moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- 主视觉区域 -->
  <main class="hero-section">
    <!-- 动漫角色立绘区域 -->
    <div class="character-section">
      <div class="character-frame">
        <!-- 装饰性樱花树枝 -->
        <div class="sakura-branch sakura-branch-left">
          <svg viewBox="0 0 200 300" class="branch-svg">
            <defs>
              <linearGradient id="branchGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#8B4513;stop-opacity:0.8" />
                <stop offset="100%" style="stop-color:#654321;stop-opacity:0.6" />
              </linearGradient>
            </defs>
            <path d="M100 300 Q80 250 60 200 Q40 150 80 100 Q120 50 100 0"
                  stroke="url(#branchGradient)" stroke-width="8" fill="none" stroke-linecap="round"/>
            <g class="branch-flowers">
              <circle cx="80" cy="100" r="15" fill="#FFB6C1" opacity="0.9"/>
              <circle cx="75" cy="95" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="85" cy="95" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="80" cy="85" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="72" cy="105" r="6" fill="#FFC0CB" opacity="0.7"/>
              <circle cx="88" cy="105" r="6" fill="#FFC0CB" opacity="0.7"/>
              <circle cx="60" cy="150" r="12" fill="#FFD1DC" opacity="0.8"/>
              <circle cx="55" cy="145" r="6" fill="#FFB6C1" opacity="0.7"/>
              <circle cx="65" cy="145" r="6" fill="#FFB6C1" opacity="0.7"/>
              <circle cx="60" cy="140" r="6" fill="#FFB6C1" opacity="0.7"/>
              <circle cx="120" cy="80" r="14" fill="#FFE4E8" opacity="0.85"/>
              <circle cx="115" cy="75" r="7" fill="#FFC0CB" opacity="0.75"/>
              <circle cx="125" cy="75" r="7" fill="#FFC0CB" opacity="0.75"/>
              <circle cx="120" cy="68" r="7" fill="#FFC0CB" opacity="0.75"/>
            </g>
          </svg>
        </div>

        <div class="sakura-branch sakura-branch-right">
          <svg viewBox="0 0 200 300" class="branch-svg">
            <path d="M100 300 Q120 250 140 200 Q160 150 120 100 Q80 50 100 0"
                  stroke="url(#branchGradient)" stroke-width="8" fill="none" stroke-linecap="round"/>
            <g class="branch-flowers">
              <circle cx="120" cy="100" r="15" fill="#FFB6C1" opacity="0.9"/>
              <circle cx="115" cy="95" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="125" cy="95" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="120" cy="85" r="8" fill="#FF69B4" opacity="0.8"/>
              <circle cx="140" cy="150" r="12" fill="#FFD1DC" opacity="0.8"/>
              <circle cx="80" cy="80" r="14" fill="#FFE4E8" opacity="0.85"/>
            </g>
          </svg>
        </div>

        <!-- 角色立绘占位 - 这里放置实际的动漫角色图片 -->
        <div class="character-placeholder">
          <div class="character-glow"></div>
          <div class="character-silhouette">
            <svg viewBox="0 0 400 600" class="silhouette-svg">
              <!-- 简化的角色轮廓示例 -->
              <defs>
                <linearGradient id="hairGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#FFB6C1;stop-opacity:0.9" />
                  <stop offset="50%" style="stop-color:#FF69B4;stop-opacity:0.8" />
                  <stop offset="100%" style="stop-color:#DB7093;stop-opacity:0.7" />
                </linearGradient>
                <linearGradient id="skinGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#FFFAF0;stop-opacity:0.95" />
                  <stop offset="100%" style="stop-color:#FFE4E1;stop-opacity:0.9" />
                </linearGradient>
              </defs>
              <!-- 长发 -->
              <path d="M120 150 Q80 200 100 350 Q120 450 140 550 L160 550 Q150 400 160 250 Q170 150 200 120 Q230 150 240 250 Q250 400 240 550 L260 550 Q280 450 300 350 Q320 200 280 150 Q250 100 200 80 Q150 100 120 150"
                    fill="url(#hairGradient)" opacity="0.9"/>
              <!-- 脸部 -->
              <ellipse cx="200" cy="180" rx="60" ry="70" fill="url(#skinGradient)"/>
              <!-- 眼睛 -->
              <ellipse cx="175" cy="175" rx="12" ry="15" fill="#4A4A4A"/>
              <ellipse cx="225" cy="175" rx="12" ry="15" fill="#4A4A4A"/>
              <circle cx="178" cy="172" r="4" fill="#FFF"/>
              <circle cx="228" cy="172" r="4" fill="#FFF"/>
              <!-- 微笑 -->
              <path d="M180 200 Q200 215 220 200" stroke="#FF6B9C" stroke-width="3" fill="none" stroke-linecap="round"/>
              <!-- 身体轮廓 -->
              <path d="M160 250 Q150 300 140 400 Q135 500 150 600 L250 600 Q265 500 260 400 Q250 300 240 250 Q220 240 200 240 Q180 240 160 250"
                    fill="#FFF" opacity="0.8"/>
            </svg>
          </div>
          <div class="character-label">桜の少女</div>
        </div>
      </div>
    </div>

    <!-- 个人资料卡片 -->
    <aside class="profile-card glassmorphism">
      <div class="profile-inner">
        <!-- 头像区域 -->
        <div class="avatar-section">
          <div class="avatar-wreath">
            <svg viewBox="0 0 120 120" class="wreath-svg">
              <!-- 花环装饰 -->
              <circle cx="60" cy="10" r="6" fill="#FFB6C1" opacity="0.8"/>
              <circle cx="30" cy="25" r="5" fill="#FF69B4" opacity="0.7"/>
              <circle cx="90" cy="25" r="5" fill="#FF69B4" opacity="0.7"/>
              <circle cx="15" cy="55" r="5" fill="#FFC0CB" opacity="0.7"/>
              <circle cx="105" cy="55" r="5" fill="#FFC0CB" opacity="0.7"/>
              <circle cx="20" cy="85" r="5" fill="#FFD1DC" opacity="0.7"/>
              <circle cx="100" cy="85" r="5" fill="#FFD1DC" opacity="0.7"/>
              <circle cx="45" cy="105" r="5" fill="#FFE4E8" opacity="0.7"/>
              <circle cx="75" cy="105" r="5" fill="#FFE4E8" opacity="0.7"/>
            </svg>
          </div>
          <div class="avatar-wrapper">
            <div class="avatar-glow-effect"></div>
            <div class="avatar-circle">
              <img
                src={backgroundWallpaper.banner?.avatar?.imageSrc || "/assets/images/default-avatar.png"}
                alt="Avatar"
                class="avatar-img"
                style={`object-position: ${backgroundWallpaper.banner?.avatar?.imagePosition || "center"};`}
              />
            </div>
            <div class="online-status">
              <span class="status-dot"></span>
            </div>
          </div>
        </div>

        <!-- 用户信息 -->
        <div class="user-info">
          <h2 class="user-name">{backgroundWallpaper.banner?.avatar?.label || "User"}</h2>
          <p class="user-bio">桜舞う季節に✨</p>
        </div>

        <!-- 社交链接 -->
        <div class="social-links">
          <a href="#" class="social-link" title="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="#" class="social-link" title="Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="#" class="social-link" title="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>
      </div>
    </aside>
  </main>

  <!-- 标题文字区域 -->
  <section class="title-section">
    <div class="title-content">
      <h1 class="main-title">
        <span class="title-char" style="animation-delay: 0.1s">生</span>
        <span class="title-char" style="animation-delay: 0.2s">命</span>
        <span class="title-char" style="animation-delay: 0.3s">不</span>
        <span class="title-char" style="animation-delay: 0.4s">止</span>
        <span class="title-char" style="animation-delay: 0.5s">，</span>
        <span class="title-char" style="animation-delay: 0.6s">折</span>
        <span class="title-char" style="animation-delay: 0.7s">腾</span>
        <span class="title-char" style="animation-delay: 0.8s">不</span>
        <span class="title-char" style="animation-delay: 0.9s">息</span>
      </h1>
      <div class="subtitle-container">
        {subtitleArray.map((text: string, index: number) => (
          <p class="subtitle" style={`animation-delay: ${1 + index * 0.2}s`}>{text}</p>
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  /* ===== 基础变量 ===== */
  :root {
    --sakura-pink: #FFB6C1;
    --sakura-light: #FFD1DC;
    --sakura-dark: #DB7093;
    --cherry-blossom: #FF69B4;
    --cream-white: #FFFAF0;
    --soft-rose: #FFE4E1;
    --lavender-accent: #E6E6FA;
    --glass-bg: rgba(255, 255, 255, 0.15);
    --glass-border: rgba(255, 255, 255, 0.3);
    --glass-shadow: rgba(255, 182, 193, 0.25);
  }

  /* ===== 容器 ===== */
  .sakura-homepage {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--cream-white) 0%,
      var(--soft-rose) 30%,
      var(--sakura-light) 60%,
      var(--lavender-accent) 100%
    );
  }

  /* ===== 背景装饰 ===== */
  .background-decorations {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .light-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: blob-float 20s ease-in-out infinite;
  }

  .light-blob-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--sakura-pink) 0%, transparent 70%);
    top: -200px;
    left: -200px;
    animation-delay: 0s;
  }

  .light-blob-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--lavender-accent) 0%, transparent 70%);
    bottom: -150px;
    right: -150px;
    animation-delay: -7s;
  }

  .light-blob-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--soft-rose) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -14s;
  }

  @keyframes blob-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(30px, -30px) scale(1.05);
    }
    50% {
      transform: translate(-20px, 20px) scale(0.95);
    }
    75% {
      transform: translate(20px, 30px) scale(1.02);
    }
  }

  /* ===== 花瓣装饰群 ===== */
  .petal-cluster {
    position: absolute;
    opacity: 0.7;
  }

  .petal-cluster-1 {
    top: 10%;
    left: 5%;
    animation: cluster-drift 15s ease-in-out infinite;
  }

  .petal-cluster-2 {
    bottom: 15%;
    right: 8%;
    animation: cluster-drift 18s ease-in-out infinite reverse;
  }

  .deco-petal {
    display: block;
    width: 12px;
    height: 12px;
    background: linear-gradient(135deg, var(--sakura-light) 0%, var(--cherry-blossom) 100%);
    border-radius: 50% 0 50% 50%;
    margin: 8px;
    box-shadow: 0 0 8px rgba(255, 182, 193, 0.5);
  }

  .petal-cluster .deco-petal:nth-child(2) {
    width: 8px;
    height: 8px;
    margin-left: 20px;
    animation: petal-float 4s ease-in-out infinite;
  }

  .petal-cluster .deco-petal:nth-child(3) {
    width: 6px;
    height: 6px;
    margin-left: 10px;
    animation: petal-float 5s ease-in-out infinite;
    animation-delay: 1s;
  }

  @keyframes cluster-drift {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    50% {
      transform: translate(20px, -20px) rotate(10deg);
    }
  }

  @keyframes petal-float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.7;
    }
    50% {
      transform: translateY(-15px) rotate(180deg);
      opacity: 1;
    }
  }

  /* ===== 导航栏 ===== */
  .anime-navbar {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: 90%;
    max-width: 1200px;
  }

  .navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.4) 0%,
      rgba(255, 255, 255, 0.2) 50%,
      rgba(255, 240, 245, 0.3) 100%
    );
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 1.25rem;
    box-shadow:
      0 8px 32px var(--glass-shadow),
      0 2px 8px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .brand-icon {
    font-size: 1.5rem;
    animation: icon-bounce 2s ease-in-out infinite;
  }

  @keyframes icon-bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  .brand-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #5D4E55;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  }

  .navbar-menu {
    display: flex;
    gap: 0.5rem;
  }

  .nav-link {
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #6B5B62;
    text-decoration: none;
    border-radius: 0.75rem;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active {
    background: linear-gradient(
      135deg,
      rgba(255, 182, 193, 0.4) 0%,
      rgba(255, 210, 220, 0.3) 100%
    );
    color: #8B5A6B;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 182, 193, 0.3);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, var(--cherry-blossom), var(--sakura-pink));
    border-radius: 1px;
  }

  .navbar-actions {
    display: flex;
    gap: 0.5rem;
  }

  .nav-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    color: #6B5B62;
  }

  .nav-btn:hover {
    background: linear-gradient(
      135deg,
      rgba(255, 182, 193, 0.5) 0%,
      rgba(255, 210, 220, 0.4) 100%
    );
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(255, 182, 193, 0.4);
  }

  .btn-icon {
    width: 18px;
    height: 18px;
  }

  .theme-btn .moon-icon {
    display: none;
  }

  :root.dark .theme-btn .sun-icon {
    display: none;
  }

  :root.dark .theme-btn .moon-icon {
    display: block;
  }

  /* ===== 主视觉区域 ===== */
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 6rem 2rem 2rem;
    z-index: 1;
  }

  /* ===== 角色立绘区域 ===== */
  .character-section {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .character-frame {
    position: relative;
    width: 400px;
    height: 600px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ===== 樱花树枝装饰 ===== */
  .sakura-branch {
    position: absolute;
    top: 0;
    width: 200px;
    height: 300px;
    opacity: 0.9;
    z-index: 2;
  }

  .sakura-branch-left {
    left: -50px;
    transform: rotate(15deg);
    animation: branch-sway 8s ease-in-out infinite;
  }

  .sakura-branch-right {
    right: -50px;
    transform: rotate(-15deg) scaleX(-1);
    animation: branch-sway 8s ease-in-out infinite reverse;
  }

  @keyframes branch-sway {
    0%, 100% {
      transform: rotate(15deg);
    }
    50% {
      transform: rotate(18deg);
    }
  }

  .branch-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 4px 8px rgba(139, 69, 19, 0.3));
  }

  /* ===== 角色占位 ===== */
  .character-placeholder {
    position: relative;
    z-index: 1;
  }

  .character-glow {
    position: absolute;
    inset: -30px;
    background: radial-gradient(
      circle,
