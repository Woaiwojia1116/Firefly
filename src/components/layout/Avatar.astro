---
interface Props {
	imageSrc?: string;
	imageAlt?: string;
	label?: string;
	imagePosition?: string;
}

const {
	imageSrc,
	imageAlt = "Avatar",
	label = "文字",
	imagePosition = "center",
} = Astro.props;
---

<div class="avatar-container">
  <div class="avatar-ring">
    <!-- 头像嵌入圆环中央 -->
    <img
      src={imageSrc || "/assets/images/default-avatar.png"}
      alt={imageAlt}
      class="avatar-image"
      style={`object-position: ${imagePosition};`}
    />
    <!-- 标签 - 覆盖在图片底部 -->
    <div class="avatar-label">
      <span class="label-dot">❀</span><span class="label-text">{label}</span>
    </div>
  </div>
</div>

<style>
  /* ===== 容器 ===== */
  .avatar-container {
    position: absolute;
    top: 8rem;
    right: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
    animation: avatar-float 6s ease-in-out infinite;
  }

  @keyframes avatar-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }

  /* ===== 圆环外框 ===== */
  .avatar-ring {
    position: relative;
    width: 160px;
    height: 160px;
    background-image: url("/assets/images/image_692982590189355.png");
    background-size: 120%;
    background-repeat: no-repeat;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s ease;
  }

  .avatar-ring:hover {
    transform: translateY(-5px);
  }

  /* ===== 头像 ===== */
  .avatar-image {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .avatar-container:hover .avatar-image {
    transform: rotate(360deg);
  }

  /* ===== 标签 ===== */
  .avatar-label {
    position: absolute;
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.55rem 1.5rem;
    z-index: 5;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 1.25rem;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.1),
      inset 0 1px 1px rgba(255, 255, 255, 0.3);
    animation: label-glow 3s ease-in-out infinite;
    white-space: nowrap;
    pointer-events: none;
  }

  @keyframes label-glow {
    0%, 100% {
      box-shadow:
        0 0 12px 2px rgba(255, 215, 100, 0.3),
        0 2px 8px rgba(255, 182, 193, 0.25),
        inset 0 0 8px rgba(255, 235, 180, 0.2);
      border-color: rgba(255, 215, 140, 0.6);
    }
    50% {
      box-shadow:
        0 0 16px 3px rgba(255, 215, 100, 0.4),
        0 2px 10px rgba(255, 182, 193, 0.3),
        inset 0 0 12px rgba(255, 235, 180, 0.3);
      border-color: rgba(255, 220, 150, 0.8);
    }
  }

  .label-dot {
    font-size: 1.1rem;
    font-weight: 900;
    color: #d4587a;
    margin-right: 0.25em;
    line-height: 1;
  }

  .label-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: #c04468;
    text-shadow:
      0 1px 2px rgba(255, 255, 255, 0.6),
      0 0 8px rgba(255, 105, 180, 0.6),
      0 0 16px rgba(255, 105, 180, 0.35),
      0 0 28px rgba(255, 105, 180, 0.2);
    letter-spacing: 0.08em;
  }

  /* ===== 暗色主题 ===== */
  :root.dark .avatar-label {
    background: rgba(40, 30, 45, 0.35);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.3),
      inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  :root.dark .label-dot {
    color: #e88aaa;
  }

  :root.dark .label-text {
    color: #f0a0be;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.5),
      0 0 8px rgba(255, 105, 180, 0.6),
      0 0 16px rgba(255, 105, 180, 0.35),
      0 0 28px rgba(255, 105, 180, 0.2);
  }

  /* ===== 移动端 ===== */
  @media (max-width: 1023px) {
    .avatar-container {
      top: 6rem;
      right: 1.5rem;
    }

    .avatar-ring {
      width: 120px;
      height: 120px;
    }

    .avatar-image {
      width: 80px;
      height: 80px;
    }

    .avatar-label {
      bottom: 6px;
      padding: 0.35rem 0.8rem;
    }

    .label-text {
      font-size: 0.8rem;
    }
  }

  /* ===== 响应式隐藏 ===== */
  body:not(.homepage) .avatar-container,
  html[data-wallpaper-mode="none"] .avatar-container {
    display: none !important;
  }
</style>
