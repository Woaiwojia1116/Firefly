---
import { commentConfig } from "@/config/commentConfig";
import { url } from "@/utils/url-utils";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="tcomment"></div>
<!-- 使用自编译的 Twikoo 文件，避免点赞等按钮导致页面触发滚动回顶部 https://github.com/twikoojs/twikoo/issues/721 -->
<script is:inline src={url("/assets/js/twikoo.nocss.js")}></script>
<link rel="stylesheet" href={url("/assets/css/twikoo.css")} />
<link rel="stylesheet" href={url("/assets/css/twikoo-custom.css")} />
<script is:inline define:vars={{ config }}>
  // 获取当前页面路径
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  // 动态创建配置对象
  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  // 初始化 Twikoo
  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        commentEl.innerHTML = "";

        const dynamicConfig = createTwikooConfig();
        console.log("[Twikoo] 初始化配置:", dynamicConfig);

        twikoo
          .init(dynamicConfig)
          .then(() => {
            console.log("[Twikoo] 初始化完成");
            // 延迟执行，等待 Twikoo 渲染评论
            setTimeout(applyMasterTag, 500);
            // 再次延迟，确保异步评论加载完成
            setTimeout(applyMasterTag, 1500);
            setTimeout(applyMasterTag, 3000);
          })
          .catch((error) => {
            console.error("[Twikoo] 初始化失败:", error);
          });
      }
    } else {
      // 如果 Twikoo 未加载，稍后重试
      setTimeout(initTwikoo, 500);
    }
  }

  // 给博主评论添加标签
  function applyMasterTag() {
    const masterTag = config.masterTag;
    console.log("[Twikoo] applyMasterTag 执行, masterTag:", masterTag);
    if (!masterTag || !masterTag.label) {
      console.log("[Twikoo] masterTag 配置缺失，跳过");
      return;
    }

    const comments = document.querySelectorAll(".tk-comment");
    console.log("[Twikoo] 找到评论数量:", comments.length);
    if (comments.length === 0) return;

    // 打印第一个评论的 HTML 结构，帮助调试
    if (comments[0]) {
      console.log("[Twikoo] 第一个评论 HTML:", comments[0].innerHTML.substring(0, 500));
    }

    comments.forEach((comment) => {
      let isMaster = false;
      let matchedBy = "";

      // 优先匹配昵称（始终可见，推荐）
      if (masterTag.nickname) {
        const nickEl = comment.querySelector(".tk-nick-link");
        if (nickEl) {
          const nick = nickEl.textContent?.trim();
          console.log("[Twikoo] 找到昵称:", nick, "期望:", masterTag.nickname);
          if (nick === masterTag.nickname) {
            isMaster = true;
            matchedBy = "nickname";
          }
        } else {
          // 尝试其他可能的选择器
          const altNickEl = comment.querySelector(".tk-nick");
          if (altNickEl) {
            const nick = altNickEl.textContent?.trim();
            console.log("[Twikoo] 找到昵称(.tk-nick):", nick);
            if (nick === masterTag.nickname) {
              isMaster = true;
              matchedBy = "nickname-alt";
            }
          }
        }
      }

      // 备选：匹配邮箱（需 Twikoo 前端显示邮箱）
      if (!isMaster && masterTag.email) {
        const emailEl = comment.querySelector(".tk-email");
        if (emailEl) {
          const email = emailEl.textContent?.trim().toLowerCase();
          if (email === masterTag.email.toLowerCase()) {
            isMaster = true;
            matchedBy = "email";
          }
        }
      }

      if (!isMaster) return;

      console.log("[Twikoo] 匹配到博主评论，匹配方式:", matchedBy);

      // 避免重复添加
      if (comment.querySelector(".firefly-master-tag")) return;

      const nickEl = comment.querySelector(".tk-nick-link") || comment.querySelector(".tk-nick");
      if (!nickEl) return;

      const tag = document.createElement("span");
      tag.className = "firefly-master-tag";
      tag.textContent = masterTag.label;
      tag.style.cssText = `
        display: inline-block;
        margin-left: 6px;
        padding: 1px 6px;
        font-size: 11px;
        font-weight: 500;
        line-height: 1.4;
        border-radius: 4px;
        background-color: ${masterTag.bgColor || "#ff6b6b"};
        color: ${masterTag.textColor || "#fff"};
        vertical-align: middle;
        white-space: nowrap;
      `;

      nickEl.parentNode?.insertBefore(tag, nickEl.nextSibling);
      console.log("[Twikoo] 标签已添加");
    });
  }

  // 监听评论加载完成（Twikoo 异步渲染评论）
  function observeComments() {
    const masterTag = config.masterTag;
    if (!masterTag || (!masterTag.nickname && !masterTag.email)) return;

    const observer = new MutationObserver(() => {
      applyMasterTag();
    });

    const commentContainer = document.querySelector(".tk-comments");
    if (commentContainer) {
      observer.observe(commentContainer, { childList: true, subtree: true });
      console.log("[Twikoo] MutationObserver 已启动");
    } else {
      console.log("[Twikoo] 未找到 .tk-comments 容器");
    }
  }

  // 页面加载时初始化
  document.addEventListener("DOMContentLoaded", () => {
    initTwikoo();
    observeComments();
  });

  // Swup 页面切换后重新初始化
  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(() => {
        initTwikoo();
        observeComments();
      }, 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(() => {
            initTwikoo();
            observeComments();
          }, 200);
        });
      }
    });
  }

  // 自定义事件监听
  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.log("[Twikoo] 通过自定义事件重新初始化");
      initTwikoo();
      observeComments();
    }
  });
</script>
