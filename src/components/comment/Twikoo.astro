---
import { commentConfig } from "@/config/commentConfig";
import { url } from "@/utils/url-utils";

interface Props {
	path: string;
}
---

<div id="tcomment"></div>
<!-- 使用自编译的 Twikoo 文件，避免点赞等按钮导致页面触发滚动回顶部 https://github.com/twikoojs/twikoo/issues/721 -->
<script is:inline src={url("/assets/js/twikoo.nocss.js")}></script>
<link rel="stylesheet" href={url("/assets/css/twikoo.css")} />
<link rel="stylesheet" href={url("/assets/css/twikoo-custom.css")} />
<script is:inline define:vars={{ masterTag: commentConfig.twikoo?.masterTag }}>
  // 获取当前页面路径
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  // 动态创建配置对象
  function createTwikooConfig() {
    return {
      envId: "https://twokoo.ccwu.cc",
      lang: "zh-CN",
      visitorCount: false,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  // 初始化 Twikoo
  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        const dynamicConfig = createTwikooConfig();

        twikoo
          .init(dynamicConfig)
          .then(() => {
            // 兜底：初始渲染可能用 innerHTML 批量写入，observer 补标签
            observeComments();
          })
          .catch((error) => {
            console.error("[Twikoo] 初始化失败:", error);
          });
      }
    } else {
      // 如果 Twikoo 未加载，稍后重试
      setTimeout(initTwikoo, 500);
    }
  }

  // 给单条评论添加标签（在元素插入 DOM 前调用）
  function addTagToComment(comment) {
    if (!masterTag || !masterTag.label) return;
    if (comment.querySelector(".firefly-master-tag")) return;

    let isMaster = false;

    if (masterTag.nickname) {
      const nickEl = comment.querySelector(".tk-nick-link") || comment.querySelector(".tk-nick");
      if (nickEl && nickEl.textContent.trim() === masterTag.nickname) {
        isMaster = true;
      }
    }

    if (!isMaster && masterTag.email) {
      const emailEl = comment.querySelector(".tk-email");
      if (emailEl && emailEl.textContent.trim().toLowerCase() === masterTag.email.toLowerCase()) {
        isMaster = true;
      }
    }

    if (!isMaster) return;

    const nickEl = comment.querySelector(".tk-nick-link") || comment.querySelector(".tk-nick");
    if (!nickEl) return;

    const tag = document.createElement("span");
    tag.className = "firefly-master-tag";
    tag.textContent = masterTag.label;
    tag.style.cssText = `
      display: inline-block;
      margin-left: 6px;
      padding: 1px 6px;
      font-size: 11px;
      font-weight: 500;
      line-height: 1.4;
      border-radius: 4px;
      background-color: ${masterTag.bgColor || "#ff6b6b"};
      color: ${masterTag.textColor || "#fff"};
      vertical-align: middle;
      white-space: nowrap;
    `;

    nickEl.parentNode?.insertBefore(tag, nickEl.nextSibling);
  }

  // 给博主评论添加标签（批量，用于 observer 回调）
  function applyMasterTag() {
    const comments = document.querySelectorAll(".tk-comment:not(.firefly-master-tag)");
    comments.forEach(addTagToComment);
  }

  // 拦截容器 DOM 插入方法，在评论插入前同步加标签
  function patchCommentContainer() {
    const container = document.getElementById("tcomment");
    if (!container || container.__fireflyPatched) return;

    const methods = ["appendChild", "insertBefore", "append", "prepend"];

    for (const method of methods) {
      const original = container[method];
      if (!original) continue;

      container[method] = function (...args) {
        const nodes = args[0] instanceof NodeList ? Array.from(args[0]) : [args[0]];

        for (const node of nodes) {
          if (node.nodeType !== Node.ELEMENT_NODE) continue;
          const comments = node.classList?.contains("tk-comment")
            ? [node]
            : node.querySelectorAll?.(".tk-comment") || [];
          comments.forEach(addTagToComment);
        }

        return original.apply(this, args);
      };
    }

    container.__fireflyPatched = true;
  }

  // 监听评论加载完成（Twikoo 异步渲染评论）
  function observeComments() {
    if (!masterTag || (!masterTag.nickname && !masterTag.email)) return;

    // 拦截 DOM 插入，标签和评论同步出现
    patchCommentContainer();

    // 立即执行一次，处理 init 已完成后的初始渲染
    applyMasterTag();

    // 用 rAF 合并同帧内的多次 DOM 变更，作为兜底
    let rafId = null;
    const scheduleApply = () => {
      if (rafId !== null) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        applyMasterTag();
      });
    };

    const observer = new MutationObserver(scheduleApply);

    const target = document.querySelector("#tcomment");
    if (target) {
      observer.observe(target, { childList: true, subtree: true });
    }

    // 定时轮询兜底：30 秒后自动停止
    let elapsed = 0;
    const fallback = setInterval(() => {
      elapsed += 1000;
      if (elapsed >= 30000) {
        clearInterval(fallback);
        return;
      }
      scheduleApply();
    }, 1000);
  }

  // 页面加载时初始化
  document.addEventListener("DOMContentLoaded", () => {
    initTwikoo();
  });

  // Swup 页面切换后重新初始化
  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(() => {
        initTwikoo();
      }, 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(() => {
            initTwikoo();
          }, 200);
        });
      }
    });
  }

  // 自定义事件监听
  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.log("[Twikoo] 通过自定义事件重新初始化");
      initTwikoo();
    }
  });
</script>
