---
import CoverImage from "@components/common/CoverImage.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getFileDirFromPath, getPostUrlBySlug } from "@utils/url-utils";
import type { ImageMetadata } from "astro";
import mikuAvatar from "@/assets/images/miku.png";
import { backgroundWallpaper } from "@/config";
import { getPostsForTimeline } from "@/utils/content-utils";

// ── Types ────────────────────────────────────────────────────────────────
interface ArticleInfo {
	id: string;
	title: string;
	published: Date;
	image?: string;
	timelineOnly?: boolean;
}

interface MonthGroup {
	month: number; // 1–12
	articles: ArticleInfo[];
}

interface YearGroup {
	year: number;
	months: MonthGroup[];
}

// ── Fetch & group posts: year → month → articles ─────────────────────────
const allPosts = await getPostsForTimeline();

const groupedMap = new Map<number, Map<number, ArticleInfo[]>>();

for (const post of allPosts) {
	const date = new Date(post.data.published);
	const year = date.getFullYear();
	const month = date.getMonth() + 1;

	if (!groupedMap.has(year)) groupedMap.set(year, new Map());
	const yearMap = groupedMap.get(year)!;
	if (!yearMap.has(month)) yearMap.set(month, []);
	yearMap.get(month)!.push({
		id: post.id,
		title: post.data.title,
		published: date,
		image: post.data.image as string | undefined,
		timelineOnly: post.data.timelineOnly,
	});
}

// Sort years & months descending; articles within a month also descending
const yearGroups: YearGroup[] = [];
for (const [year, monthMap] of [...groupedMap.entries()].sort(
	(a, b) => b[0] - a[0],
)) {
	const months: MonthGroup[] = [];
	for (const [month, articles] of [...monthMap.entries()].sort(
		(a, b) => b[0] - a[0],
	)) {
		articles.sort((a, b) => b.published.getTime() - a.published.getTime());
		months.push({ month, articles });
	}
	yearGroups.push({ year, months });
}

// ── Calendar month i18n key lookup ───────────────────────────────────────
const CALENDAR_MONTH_KEYS: Record<number, I18nKey> = {
	1: I18nKey.calendarJanuary,
	2: I18nKey.calendarFebruary,
	3: I18nKey.calendarMarch,
	4: I18nKey.calendarApril,
	5: I18nKey.calendarMay,
	6: I18nKey.calendarJune,
	7: I18nKey.calendarJuly,
	8: I18nKey.calendarAugust,
	9: I18nKey.calendarSeptember,
	10: I18nKey.calendarOctober,
	11: I18nKey.calendarNovember,
	12: I18nKey.calendarDecember,
};

// ── Image helpers ────────────────────────────────────────────────────────
function hasLocalImage(src: string | undefined): boolean {
	if (!src || src === "api") return false;
	return src.startsWith("./");
}

function hasRemoteImage(src: string | undefined): boolean {
	if (!src || src === "api") return false;
	return src.startsWith("/") || src.startsWith("http");
}

// ── Date formatter ───────────────────────────────────────────────────────
function fmtDate(d: Date): string {
	return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}

// ── Resolve background image ──────────────────────────────────────────────
const bgPath = backgroundWallpaper.timelineBg;
let bgSrc = "";
if (bgPath && !bgPath.startsWith("http") && !bgPath.startsWith("/")) {
	const images = import.meta.glob<{ default: ImageMetadata }>(
		"/src/assets/**/*.{jpg,jpeg,png,webp,avif}",
	);
	const key = `/src/${bgPath}`;
	const loader = images[key];
	if (loader) {
		const mod = await loader();
		bgSrc = mod.default.src;
	}
} else if (bgPath) {
	bgSrc = bgPath;
}

// Global stagger index across all cards on the page
let animIdx = 0;
---

<MainGridLayout title={i18n(I18nKey.timeline)} minimal={true}>
  {bgSrc && (
    <div id="tl-bg">
      <img src={bgSrc} alt="" />
    </div>
  )}
  <div class="tl">
    {
      yearGroups.length === 0 ? (
        <p class="tl-empty">{i18n(I18nKey.searchNoResults)}</p>
      ) : (
        yearGroups.map((yg) => {
          const yearTotal = yg.months.reduce(
            (s, m) => s + m.articles.length,
            0,
          );
          return (
            <div class="tl-year" data-tl-toggle>
              {/* ── Year header ─────────────────────────── */}
              <button class="tl-year-summary" data-tl-trigger>
                <span class="tl-year-text">{yg.year}</span>
                <span class="tl-year-count">
                  &middot; {yearTotal}{" "}
                  {i18n(
                    yearTotal === 1
                      ? I18nKey.eventCount
                      : I18nKey.eventsCount,
                  )}
                </span>
                <svg class="tl-toggle-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>

              {/* ── Months under this year ─────────────── */}
              <div class="tl-year-body" data-tl-body>
                {yg.months.map((mg, mIdx) => {
                  const mc = mg.articles.length;
                  return (
                    <div class="tl-month" data-tl-toggle>
                      {/* ── Month node + label ────────── */}
                      <button class="tl-month-summary" data-tl-trigger>
                        <span class="tl-month-dot" />
                        <span class="tl-month-label">
                          {i18n(CALENDAR_MONTH_KEYS[mg.month])}
                        </span>
                        <span class="tl-month-count">
                          &middot; {mc}{" "}
                          {i18n(
                            mc === 1
                              ? I18nKey.eventCount
                              : I18nKey.eventsCount,
                          )}
                        </span>
                        <svg class="tl-toggle-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>

                      {/* ── Article cards ──────────────── */}
                      <div class="tl-cards" data-tl-body>
                        {mg.articles.map((a) => {
                          const idx = animIdx++;
                          const delay = idx * 80;
                          const cardSide = idx % 2 === 0 ? "left" : "right";
                          const imgBasePath = getFileDirFromPath(
                            `src/content/posts/${a.id}`,
                          );
                          const localImg = hasLocalImage(a.image);
                          const remoteImg = hasRemoteImage(a.image);
                          const showImg = localImg || remoteImg;

                          return (
                            <div
                              class="tl-card-row"
                              style={`--stagger-delay: ${delay}ms`}
                            >
                              <span class="tl-card-dot" />
                              {a.timelineOnly ? (
                                <div
                                  class={`tl-card tl-card--${cardSide}`}
                                >
                                  <div class="tl-card-body">
                                    <h3 class="tl-card-title text-90">
                                      {a.title}
                                    </h3>
                                    <time
                                      class="tl-card-date text-75"
                                      datetime={a.published.toISOString()}
                                    >
                                      {fmtDate(a.published)}
                                    </time>
                                  </div>
                                </div>
                              ) : (
                                <a
                                  href={getPostUrlBySlug(a.id)}
                                  class={`tl-card tl-card--${cardSide}`}
                                >
                                  <div class="tl-card-body">
                                    <h3 class="tl-card-title text-90">
                                      {a.title}
                                    </h3>
                                    <time
                                      class="tl-card-date text-75"
                                      datetime={a.published.toISOString()}
                                    >
                                      {fmtDate(a.published)}
                                    </time>
                                  </div>
                                  {showImg && (
                                    <div class="tl-card-img-side">
                                      {localImg ? (
                                        <CoverImage
                                          src={a.image!}
                                          basePath={imgBasePath}
                                          alt={a.title}
                                        />
                                      ) : (
                                        <img
                                          src={a.image}
                                          alt={a.title}
                                          loading="lazy"
                                          decoding="async"
                                        />
                                      )}
                                    </div>
                                  )}
                                </a>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })
      )
    }
  </div>

</MainGridLayout>

<style>
  /* ===================================================================
     Container & central line
     =================================================================== */
  .tl {
    position: relative;
    padding: 6rem 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    --tl-dot: 12px;   /* node diameter */
    --tl-line: 2px;   /* central line thickness */
  }

  /* Vertical centre line — 生长动画 */
  .tl::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: var(--tl-line);
    background: var(--line-divider);
    transform: translateX(-50%) scaleY(0);
    transform-origin: top center;
    border-radius: 1px;
    animation: tl-line-grow 1.5s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
  }

  @keyframes tl-line-grow {
    to { transform: translateX(-50%) scaleY(1); }
  }

  .tl-empty {
    text-align: center;
    color: var(--btn-content);
    padding: 3rem 1rem;
  }

  /* ===================================================================
     Year section (<details>)
     =================================================================== */
  .tl-year {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .tl-year-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    cursor: pointer;
    list-style: none;
    padding: 0.5rem 0 0.7rem;
    margin-bottom: 0.75rem;
    position: relative;
    user-select: none;
    opacity: 0;
    animation: tl-fade-in 0.6s ease 0.3s forwards;
    background: none;
    border: none;
    width: 100%;
    font: inherit;
    color: inherit;
  }

  @keyframes tl-fade-in {
    to { opacity: 1; }
  }

  .tl-year-summary::-webkit-details-marker {
    display: none;
  }

  .tl-year .tl-toggle-icon {
    margin-left: 0.25rem;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .tl-year[data-tl-expanded="false"] .tl-toggle-icon {
    transform: rotate(-90deg);
  }

  /* Horizontal lines extending from year text to container edges */
  .tl-year-summary::before,
  .tl-year-summary::after {
    content: "";
    position: absolute;
    top: 50%;
    height: 1px;
    background: var(--line-divider);
  }

  .tl-year-summary::before {
    right: calc(50% + 3.75rem);
    left: 0;
  }

  .tl-year-summary::after {
    left: calc(50% + 3.75rem);
    right: 0;
  }

  .tl-year-text {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.2;
    /* Small dot below the year number */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tl-year-text::after {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
    margin-top: 2px;
  }

  .tl-year-count {
    font-size: 0.75rem;
    color: var(--btn-content);
    font-weight: 400;
  }

  /* ===================================================================
     Month section (<details>)
     =================================================================== */
  .tl-month {
    position: relative;
    margin-bottom: 0.25rem;
  }

  .tl-month-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    cursor: pointer;
    list-style: none;
    padding: 0.35rem 0;
    user-select: none;
    background: none;
    border: none;
    width: 100%;
    font: inherit;
    color: inherit;
  }

  .tl-month-summary::-webkit-details-marker {
    display: none;
  }

  .tl-month .tl-toggle-icon {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .tl-month[data-tl-expanded="false"] .tl-toggle-icon {
    transform: rotate(-90deg);
  }

  /* Circular dot on the central line — 弹跳出现 */
  .tl-month-dot {
    display: block;
    width: var(--tl-dot);
    height: var(--tl-dot);
    border-radius: 50%;
    background: var(--primary);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 3px var(--page-bg);
    opacity: 0;
    transform: scale(0);
    animation: tl-bounce-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes tl-bounce-in {
    to { opacity: 1; transform: scale(1); }
  }

  .tl-month-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
  }

  .tl-month-count {
    font-size: 0.72rem;
    color: var(--btn-content);
  }

  /* ===================================================================
     Toggle body — transition for fade in / out
     =================================================================== */
  .tl-year-body,
  .tl-cards {
    overflow: hidden;
    transition:
      opacity 0.35s ease,
      max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    /* Start visible — JS will toggle via max-height */
    max-height: none;
    opacity: 1;
  }

  /* ===================================================================
     Article cards column
     =================================================================== */
  .tl-cards {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
    padding: 0.1rem 0 0.6rem;
  }

  /* Odd cards → on the left */
  .tl-card--left {
    margin-right: auto;
    margin-left: 0;
  }

  /* Even cards → on the right */
  .tl-card--right {
    margin-left: auto;
    margin-right: 0;
  }

  /* ===================================================================
     Card row (wrapper for dot + card) — 左右滑入动画
     =================================================================== */
  .tl-card-row {
    position: relative;
    padding-top: 0.5rem;
  }

  /* 左侧卡片从左滑入 */
  .tl-card--left {
    opacity: 0;
    animation: tl-slide-left 0.5s ease forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  /* 右侧卡片从右滑入 */
  .tl-card--right {
    opacity: 0;
    animation: tl-slide-right 0.5s ease forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  @keyframes tl-slide-left {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes tl-slide-right {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Node dot on the centre line — 弹跳出现 */
  .tl-card-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    z-index: 1;
    box-shadow: 0 0 0 2px var(--page-bg);
    opacity: 0;
    animation: tl-bounce-in-center 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  @keyframes tl-bounce-in-center {
    to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }

  /* ===================================================================
     Single article card
     =================================================================== */
  .tl-card {
    position: relative;
    display: flex;
    width: 42%;
    max-width: 460px;
    background: color-mix(in srgb, var(--card-bg) 45%, transparent);
    border-radius: var(--radius-large);
    overflow: visible;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  /* Slide-out image (hidden by default) */
  .tl-card-img-side {
    position: absolute;
    top: 0;
    height: 100%;
    width: 0;
    overflow: hidden;
    transition: width 0.35s ease;
    border-radius: var(--radius-large);
    z-index: 1;
    background: var(--code-bg);
  }

  .tl-card--left .tl-card-img-side {
    left: 100%;
  }

  .tl-card--right .tl-card-img-side {
    right: 100%;
  }

  .tl-card:hover .tl-card-img-side {
    width: 150px;
  }

  .tl-card-img-side :global(.cover-image-container) {
    min-height: 0;
    height: 100%;
  }

  .tl-card-img-side :global(img),
  .tl-card-img-side :global(picture) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Suppress entrance animation during Swup page-leave */
  .transition-leaving .tl-card-row,
  .transition-leaving .tl-month-dot,
  .transition-leaving .tl-card-dot,
  .transition-leaving .tl-year-summary,
  .transition-leaving .tl-year-body,
  .transition-leaving .tl-cards,
  .transition-leaving .tl::before {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
    max-height: none !important;
  }

  .tl-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  /* ── Cover image area ───────────────────────────── */
  .tl-card-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--code-bg);
  }

  .tl-card-img :global(.cover-image-container) {
    min-height: 0;
    height: 100%;
  }

  .tl-card-img :global(img),
  .tl-card-img :global(picture) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Text body ──────────────────────────────────── */
  .tl-card-body {
    padding: 0.4rem 0.65rem;
  }

  .tl-card-title {
    margin: 0 0 0.2rem;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tl-card-date {
    font-size: 0.76rem;
  }

  /* ===================================================================
     Responsive: mobile < 768 px
     =================================================================== */
  /* ===================================================================
     Background image - full screen
     =================================================================== */
  #tl-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    overflow: hidden;
  }
  #tl-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 禁用时间轴页面的弹性入场动画，使用自己的动画 */
  :global(#content-wrapper) {
    animation: none !important;
    opacity: 1 !important;
  }

  /* 始终显示右侧垂直滚动条，不显示底部水平滚动条，防止布局抖动 */
  :global(html) {
    overflow-y: scroll;
    overflow-x: hidden;
  }

  /* ===================================================================
     Navbar: 半透明背景（无毛玻璃）
     =================================================================== */
  :global(#navbar-wrapper),
  :global(#navbar > div) {
    background: color-mix(in srgb, var(--card-bg) 60%, transparent) !important;
  }

  /* ===================================================================
     Semi-transparent: timeline cards
     =================================================================== */
  .tl-card {
    background: color-mix(in srgb, var(--card-bg) 50%, transparent) !important;
    border: 1px solid color-mix(in srgb, var(--line-divider) 20%, transparent);
  }

  /* Make the right sidebar background transparent */
  .tl-card-body {
    background: transparent !important;
  }

  /* ===================================================================
     Suppress entrance animation during Swup page-leave
     =================================================================== */

  @media (max-width: 767px) {
    /* Shift the timeline line to the left */
    .tl::before {
      left: 16px;
    }

    /* Year summary aligns left */
    .tl-year-summary {
      justify-content: flex-start;
      padding-left: 2.4rem;
    }

    .tl-year-summary::before,
    .tl-year-summary::after {
      display: none;
    }

    /* Month summary aligns left (dot stays on the line) */
    .tl-month-summary {
      justify-content: flex-start;
      padding-left: 2.4rem;
    }

    /* All cards stack on the right side, full-width */
    .tl-card--left,
    .tl-card--right {
      width: 85%;
      margin-left: 2.4rem !important;
      margin-right: 0 !important;
    }

    /* Card dot aligns with the shifted timeline line */
    .tl-card-dot {
      left: 16px;
    }

    /* Slide-out image on small screens */
    .tl-card-img-side {
      border-radius: var(--radius-large);
    }

    .tl-card:hover .tl-card-img-side {
      width: 100px;
    }
  }
</style>

<script>
  // ── Timeline toggle with fade animation ──────────────────────────────
  document.querySelectorAll("[data-tl-toggle]").forEach((group) => {
    const trigger = group.querySelector("[data-tl-trigger]");
    const body = group.querySelector("[data-tl-body]");
    if (!trigger || !body) return;

    // Start expanded
    group.dataset.tlExpanded = "true";

    trigger.addEventListener("click", () => {
      const isExpanded = group.dataset.tlExpanded === "true";

      if (isExpanded) {
        // ── Collapse ──────────────────────────────────────────────
        // Lock current height first (scrollHeight is valid while expanded)
        body.style.maxHeight = body.scrollHeight + "px";
        body.style.opacity = "1";
        body.offsetHeight; // force reflow so the lock takes effect
        // In the next frame, animate to 0
        requestAnimationFrame(() => {
          body.style.maxHeight = "0px";
          body.style.opacity = "0";
        });
        group.dataset.tlExpanded = "false";
      } else {
        // ── Expand ────────────────────────────────────────────────
        // Step 1: temporarily remove max-height to measure real content height
        body.style.maxHeight = "none";
        const realHeight = body.scrollHeight;

        // Step 2: set starting state (0) in this frame
        body.style.maxHeight = "0px";
        body.style.opacity = "0";
        body.offsetHeight; // force reflow so the 0-state is committed

        // Step 3: in the NEXT frame, animate to real height
        //          (must be a separate frame or the browser merges the two
        //           maxHeight assignments and skips the transition)
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            body.style.maxHeight = realHeight + "px";
            body.style.opacity = "1";
            group.dataset.tlExpanded = "true";

            // Step 4: after transition ends, clear max-height so content can grow
            const onEnd = () => {
              if (group.dataset.tlExpanded === "true") {
                body.style.maxHeight = "none";
              }
              body.removeEventListener("transitionend", onEnd);
            };
            body.addEventListener("transitionend", onEnd);
            setTimeout(onEnd, 600); // fallback safety
          });
        });
      }
    });
  });
</script>
