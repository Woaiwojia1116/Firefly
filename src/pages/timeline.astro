---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import CoverImage from "@components/common/CoverImage.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getPostsForTimeline } from "@/utils/content-utils";
import { backgroundWallpaper } from "@/config";
import { getFileDirFromPath, getPostUrlBySlug } from "@utils/url-utils";
import type { ImageMetadata } from "astro";

// ── Types ────────────────────────────────────────────────────────────────
interface ArticleInfo {
  id: string;
  title: string;
  published: Date;
  image?: string;
  timelineOnly?: boolean;
}

interface MonthGroup {
  month: number; // 1–12
  articles: ArticleInfo[];
}

interface YearGroup {
  year: number;
  months: MonthGroup[];
}

// ── Fetch & group posts: year → month → articles ─────────────────────────
const allPosts = await getPostsForTimeline();

const groupedMap = new Map<number, Map<number, ArticleInfo[]>>();

for (const post of allPosts) {
  const date = new Date(post.data.published);
  const year = date.getFullYear();
  const month = date.getMonth() + 1;

  if (!groupedMap.has(year)) groupedMap.set(year, new Map());
  const yearMap = groupedMap.get(year)!;
  if (!yearMap.has(month)) yearMap.set(month, []);
  yearMap.get(month)!.push({
    id: post.id,
    title: post.data.title,
    published: date,
    image: post.data.image as string | undefined,
    timelineOnly: post.data.timelineOnly,
  });
}

// Sort years & months descending; articles within a month also descending
const yearGroups: YearGroup[] = [];
for (const [year, monthMap] of [...groupedMap.entries()].sort(
  (a, b) => b[0] - a[0],
)) {
  const months: MonthGroup[] = [];
  for (const [month, articles] of [...monthMap.entries()].sort(
    (a, b) => b[0] - a[0],
  )) {
    articles.sort((a, b) => b.published.getTime() - a.published.getTime());
    months.push({ month, articles });
  }
  yearGroups.push({ year, months });
}

// ── Calendar month i18n key lookup ───────────────────────────────────────
const CALENDAR_MONTH_KEYS: Record<number, I18nKey> = {
  1: I18nKey.calendarJanuary,
  2: I18nKey.calendarFebruary,
  3: I18nKey.calendarMarch,
  4: I18nKey.calendarApril,
  5: I18nKey.calendarMay,
  6: I18nKey.calendarJune,
  7: I18nKey.calendarJuly,
  8: I18nKey.calendarAugust,
  9: I18nKey.calendarSeptember,
  10: I18nKey.calendarOctober,
  11: I18nKey.calendarNovember,
  12: I18nKey.calendarDecember,
};

// ── Image helpers ────────────────────────────────────────────────────────
function hasLocalImage(src: string | undefined): boolean {
  if (!src || src === "api") return false;
  return src.startsWith("./");
}

function hasRemoteImage(src: string | undefined): boolean {
  if (!src || src === "api") return false;
  return src.startsWith("/") || src.startsWith("http");
}

// ── Date formatter ───────────────────────────────────────────────────────
function fmtDate(d: Date): string {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}

// ── Resolve background image ──────────────────────────────────────────────
const bgPath = backgroundWallpaper.timelineBg;
let bgSrc = "";
if (bgPath && !bgPath.startsWith("http") && !bgPath.startsWith("/")) {
  const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/**/*.{jpg,jpeg,png,webp,avif}",
  );
  const key = `/src/${bgPath}`;
  const loader = images[key];
  if (loader) {
    const mod = await loader();
    bgSrc = mod.default.src;
  }
} else if (bgPath) {
  bgSrc = bgPath;
}

// Global stagger index across all cards on the page
let animIdx = 0;
---

<MainGridLayout title={i18n(I18nKey.timeline)} minimal={true}>
  {bgSrc && (
    <div id="tl-bg">
      <img src={bgSrc} alt="" />
    </div>
  )}
  <div class="tl">
    {
      yearGroups.length === 0 ? (
        <p class="tl-empty">{i18n(I18nKey.searchNoResults)}</p>
      ) : (
        yearGroups.map((yg) => {
          const yearTotal = yg.months.reduce(
            (s, m) => s + m.articles.length,
            0,
          );
          return (
            <details class="tl-year" open>
              {/* ── Year header ─────────────────────────── */}
              <summary class="tl-year-summary">
                <span class="tl-year-text">{yg.year}</span>
                <span class="tl-year-count">
                  &middot; {yearTotal}{" "}
                  {i18n(
                    yearTotal === 1
                      ? I18nKey.eventCount
                      : I18nKey.eventsCount,
                  )}
                </span>
              </summary>

              {/* ── Months under this year ─────────────── */}
              <div class="tl-year-body">
                {yg.months.map((mg, mIdx) => {
                  const mc = mg.articles.length;
                  return (
                    <details class="tl-month" open>
                      {/* ── Month node + label ────────── */}
                      <summary class="tl-month-summary">
                        <span class="tl-month-dot" />
                        <span class="tl-month-label">
                          {i18n(CALENDAR_MONTH_KEYS[mg.month])}
                        </span>
                        <span class="tl-month-count">
                          &middot; {mc}{" "}
                          {i18n(
                            mc === 1
                              ? I18nKey.eventCount
                              : I18nKey.eventsCount,
                          )}
                        </span>
                      </summary>

                      {/* ── Article cards ──────────────── */}
                      <div class="tl-cards">
                        {mg.articles.map((a) => {
                          const idx = animIdx++;
                          const delay = idx * 80;
                          const cardSide = idx % 2 === 0 ? "left" : "right";
                          const imgBasePath = getFileDirFromPath(
                            `src/content/posts/${a.id}`,
                          );
                          const localImg = hasLocalImage(a.image);
                          const remoteImg = hasRemoteImage(a.image);
                          const showImg = localImg || remoteImg;

                          return (
                            <div
                              class="tl-card-row"
                              style={`--stagger-delay: ${delay}ms`}
                            >
                              <span class="tl-card-dot" />
                              {a.timelineOnly ? (
                                <div
                                  class={`tl-card tl-card--${cardSide}`}
                                >
                                  <div class="tl-card-body">
                                    <h3 class="tl-card-title text-90">
                                      {a.title}
                                    </h3>
                                    <time
                                      class="tl-card-date text-75"
                                      datetime={a.published.toISOString()}
                                    >
                                      {fmtDate(a.published)}
                                    </time>
                                  </div>
                                </div>
                              ) : (
                                <a
                                  href={getPostUrlBySlug(a.id)}
                                  class={`tl-card tl-card--${cardSide}`}
                                >
                                  <div class="tl-card-body">
                                    <h3 class="tl-card-title text-90">
                                      {a.title}
                                    </h3>
                                    <time
                                      class="tl-card-date text-75"
                                      datetime={a.published.toISOString()}
                                    >
                                      {fmtDate(a.published)}
                                    </time>
                                  </div>
                                  {showImg && (
                                    <div class="tl-card-img-side">
                                      {localImg ? (
                                        <CoverImage
                                          src={a.image!}
                                          basePath={imgBasePath}
                                          alt={a.title}
                                        />
                                      ) : (
                                        <img
                                          src={a.image}
                                          alt={a.title}
                                          loading="lazy"
                                          decoding="async"
                                        />
                                      )}
                                    </div>
                                  )}
                                </a>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    </details>
                  );
                })}
              </div>
            </details>
          );
        })
      )
    }
  </div>
</MainGridLayout>

<style>
  /* ===================================================================
     Container & central line
     =================================================================== */
  .tl {
    position: relative;
    padding: 6rem 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    --tl-dot: 12px;   /* node diameter */
    --tl-line: 2px;   /* central line thickness */
  }

  /* Vertical centre line */
  .tl::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: var(--tl-line);
    background: var(--line-divider);
    transform: translateX(-50%);
    border-radius: 1px;
  }

  .tl-empty {
    text-align: center;
    color: var(--btn-content);
    padding: 3rem 1rem;
  }

  /* ===================================================================
     Year section (<details>)
     =================================================================== */
  .tl-year {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .tl-year-summary {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.35rem;
    cursor: pointer;
    list-style: none;
    padding: 0.5rem 0 0.7rem;
    margin-bottom: 0.75rem;
    position: relative;
    user-select: none;
  }

  .tl-year-summary::-webkit-details-marker {
    display: none;
  }

  /* Horizontal lines extending from year text to container edges */
  .tl-year-summary::before,
  .tl-year-summary::after {
    content: "";
    position: absolute;
    top: 50%;
    height: 1px;
    background: var(--line-divider);
  }

  .tl-year-summary::before {
    right: calc(50% + 3.75rem);
    left: 0;
  }

  .tl-year-summary::after {
    left: calc(50% + 3.75rem);
    right: 0;
  }

  .tl-year-text {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.2;
    /* Small dot below the year number */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tl-year-text::after {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
    margin-top: 2px;
  }

  .tl-year-count {
    font-size: 0.75rem;
    color: var(--btn-content);
    font-weight: 400;
  }

  /* ===================================================================
     Month section (<details>)
     =================================================================== */
  .tl-month {
    position: relative;
    margin-bottom: 0.25rem;
  }

  .tl-month-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    cursor: pointer;
    list-style: none;
    padding: 0.35rem 0;
    user-select: none;
  }

  .tl-month-summary::-webkit-details-marker {
    display: none;
  }

  /* Circular dot on the central line */
  .tl-month-dot {
    display: block;
    width: var(--tl-dot);
    height: var(--tl-dot);
    border-radius: 50%;
    background: var(--primary);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 3px var(--page-bg);
  }

  .tl-month-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
  }

  .tl-month-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
  }

  .tl-month-count {
    font-size: 0.72rem;
    color: var(--btn-content);
  }

  /* ===================================================================
     Article cards column
     =================================================================== */
  .tl-cards {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
    padding: 0.1rem 0 0.6rem;
  }

  /* Odd cards → on the left */
  .tl-card--left {
    margin-right: auto;
    margin-left: 0;
  }

  /* Even cards → on the right */
  .tl-card--right {
    margin-left: auto;
    margin-right: 0;
  }

  /* ===================================================================
     Card row (wrapper for dot + card)
     =================================================================== */
  .tl-card-row {
    position: relative;
    padding-top: 0.5rem;
    opacity: 0;
    animation: tl-fade-up 0.5s ease forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  /* Node dot on the centre line */
  .tl-card-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    z-index: 1;
    box-shadow: 0 0 0 2px var(--page-bg);
  }

  /* ===================================================================
     Single article card
     =================================================================== */
  .tl-card {
    position: relative;
    display: flex;
    width: 42%;
    max-width: 460px;
    background: var(--card-bg);
    border-radius: var(--radius-large);
    overflow: visible;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  /* Slide-out image (hidden by default) */
  .tl-card-img-side {
    position: absolute;
    top: 0;
    height: 100%;
    width: 0;
    overflow: hidden;
    transition: width 0.35s ease;
    border-radius: var(--radius-large);
    z-index: 1;
    background: var(--code-bg);
  }

  .tl-card--left .tl-card-img-side {
    left: 100%;
  }

  .tl-card--right .tl-card-img-side {
    right: 100%;
  }

  .tl-card:hover .tl-card-img-side {
    width: 150px;
  }

  .tl-card-img-side :global(.cover-image-container) {
    min-height: 0;
    height: 100%;
  }

  .tl-card-img-side :global(img),
  .tl-card-img-side :global(picture) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Suppress entrance animation during Swup page-leave */
  .transition-leaving .tl-card-row {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .tl-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  /* ── Cover image area ───────────────────────────── */
  .tl-card-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--code-bg);
  }

  .tl-card-img :global(.cover-image-container) {
    min-height: 0;
    height: 100%;
  }

  .tl-card-img :global(img),
  .tl-card-img :global(picture) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Text body ──────────────────────────────────── */
  .tl-card-body {
    padding: 0.4rem 0.65rem;
  }

  .tl-card-title {
    margin: 0 0 0.2rem;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tl-card-date {
    font-size: 0.76rem;
  }

  /* ===================================================================
     Staggered fade-in-up keyframes
     =================================================================== */
  @keyframes tl-fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===================================================================
     Responsive: mobile < 768 px
     =================================================================== */
  /* ===================================================================
     Background image - full screen
     =================================================================== */
  #tl-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    overflow: hidden;
  }
  #tl-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===================================================================
     Glassmorphism: navbar (global - element is in MainGridLayout)
     =================================================================== */
  :global(#navbar-wrapper),
  :global(#navbar > div) {
    background: color-mix(in srgb, var(--card-bg) 20%, transparent) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
    border-bottom: 1px solid color-mix(in srgb, var(--line-divider) 30%, transparent);
    border-radius: 0 0 var(--radius-large) var(--radius-large) !important;
  }

  /* ===================================================================
     Glassmorphism: timeline cards
     =================================================================== */
  .tl-card {
    background: color-mix(in srgb, var(--card-bg) 50%, transparent) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    border: 1px solid color-mix(in srgb, var(--line-divider) 20%, transparent);
  }

  /* Make the right sidebar background transparent */
  .tl-card-body {
    background: transparent !important;
  }

  @media (max-width: 767px) {
    /* Shift the timeline line to the left */
    .tl::before {
      left: 16px;
    }

    /* Year summary aligns left */
    .tl-year-summary {
      justify-content: flex-start;
      padding-left: 2.4rem;
    }

    .tl-year-summary::before,
    .tl-year-summary::after {
      display: none;
    }

    /* Month summary aligns left (dot stays on the line) */
    .tl-month-summary {
      justify-content: flex-start;
      padding-left: 2.4rem;
    }

    /* All cards stack on the right side, full-width */
    .tl-card--left,
    .tl-card--right {
      width: 85%;
      margin-left: 2.4rem !important;
      margin-right: 0 !important;
    }

    /* Card dot aligns with the shifted timeline line */
    .tl-card-dot {
      left: 16px;
    }

    /* Slide-out image on small screens */
    .tl-card-img-side {
      border-radius: var(--radius-large);
    }

    .tl-card:hover .tl-card-img-side {
      width: 100px;
    }
  }
</style>
